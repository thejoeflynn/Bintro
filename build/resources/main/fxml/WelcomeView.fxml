<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bintro.ui.WelcomeController"
           style="-fx-background-color: #111111;">

    <VBox alignment="CENTER" spacing="24">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Logo image; the controller loads /images/bintro-logo.png. -->
        <ImageView fx:id="logoImage" fitWidth="280" preserveRatio="true"/>

        <!-- Subtitle. ALL CAPS in the literal because JavaFX CSS lacks a
             reliable text-transform; the small grey color + uppercase
             approximates the spec's letter-spaced caps. -->
        <Label text="FOOTAGE ORGANIZER"
               style="-fx-text-fill: #555555; -fx-font-size: 10px;"/>

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="newProjectButton" text="New Project"
                    onAction="#onNewProject"
                    style="-fx-background-color: #ffffff; -fx-text-fill: #111111; -fx-font-size: 12px; -fx-padding: 8 22 8 22; -fx-background-radius: 4; -fx-border-color: transparent; -fx-cursor: hand;"/>
            <Button fx:id="openProjectButton" text="Open Project"
                    onAction="#onOpenProject"
                    style="-fx-background-color: transparent; -fx-text-fill: #aaaaaa; -fx-font-size: 12px; -fx-padding: 8 22 8 22; -fx-background-radius: 4; -fx-border-color: #444444; -fx-border-width: 1; -fx-border-radius: 4; -fx-cursor: hand;"/>
        </HBox>

        <Label text="0.1.0 — Early Preview"
               style="-fx-text-fill: #444444; -fx-font-size: 10px;"/>
    </VBox>

</StackPane>
